# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Built server binary (bare, no extension)
/fdx-mcp-server

# Test binaries
*_test

# Output of 'go build'
*.out

# Dependency directories
vendor/
node_modules/

# Note: dist/ is intentionally tracked — the npm-installable bin (package.json
# "bin"/"exports") ships the built bundle so `npm install -g` needs no build step.

# Go module cache
.cache/go-build/

# IDE specific files
.idea/
.junie/
.vscode/
.ai/
.claude/
*.swp
*.bak
*.swo

# Log files
logs/
*.log

# Environment variables
.env
.env.*

# Local MCP configuration
.mcp.json


# OS generated files
.DS_Store
Thumbs.db
/test_fdx/
/tests/
/.artifacts/

# examples/ is intentionally tracked — it holds the freely-distributable
# fixture (Grog The Caveman.fdx) used by the test suite and as a sample file.