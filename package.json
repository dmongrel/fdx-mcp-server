{
  "name": "fdx-mcp-server",
  "version": "0.0.1",
  "description": "A Model Context Protocol server — Bun-first, Deno-compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "fdx-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target node --outdir dist --minify --banner \"#!/usr/bin/env node\"",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "pdf-lib": "^1.17.1",
    "zod": "^4.4.3"
  },
  "private": false
}
