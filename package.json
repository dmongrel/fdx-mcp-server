{
  "name": "fdx-mcp-server",
  "version": "0.1.0",
  "description": "A Model Context Protocol server — Bun-first, Deno-compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist --minify",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "pdf-lib": "^1.17.1",
    "zod": "^4.4.3"
  },
  "private": false
}
